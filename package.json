{
  "name": "openweathermap-typescript",
  "version": "0.1.0",
  "description": "A modern, type-safe OpenWeatherMap API wrapper for TypeScript/ESM",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "example": "tsx example/index.ts",
    "lint": "eslint src",
    "build": "tsc"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "openweathermap",
    "weather",
    "typescript",
    "api",
    "esm",
    "fetch"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "author": "charliejmoore",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.13",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "dotenv": "^17.2.0",
    "eslint": "^9.31.0",
    "eslint-plugin-prettier": "^5.5.1",
    "globals": "^16.3.0",
    "jest": "^30.0.4",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0"
  }
}
